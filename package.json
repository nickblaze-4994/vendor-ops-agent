{
  "name": "vendor-ops-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm --prefix server install && npm --prefix web install",
    "dev": "concurrently -n api,web -c blue,magenta \"npm --prefix server run dev\" \"npm --prefix web run dev\"",
    "dev:api": "npm --prefix server run dev",
    "dev:web": "npm --prefix web run dev",
    "test": "npm --prefix server test",
    "deploy": "vercel deploy --prod"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
