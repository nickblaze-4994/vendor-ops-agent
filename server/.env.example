# Copy to .env and paste your key. Without a key the app falls back to a
# deterministic rules engine so the demo still runs (responses are templated).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
PORT=8799

# Policy thresholds (deterministic guardrails)
HIGH_VALUE_PAYMENT_THRESHOLD=25000
MIN_CONFIDENCE=0.6
